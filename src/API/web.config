<?xml version="1.0" encoding="utf-8"?>
<!--
  Hand-managed web.config for the AspNetCoreModuleV2 in-process host on IIS.

  We disable dotnet publish's auto-generation of this file (see
  IsTransformWebConfigDisabled in API.csproj) so the office IIS team always gets
  these four production-critical settings out of the box:

    - startupTimeLimit="300"  IIS default is 120s; our DbInitializer migration
                              retry loop (60 * 2s) plus actual seeding can blow
                              past 120s on a cold SQL Server and trip 500.37.
                              5 minutes covers worst-case cold starts.

    - requestTimeout          Matches the startup window so long-running boot
                              requests aren't killed mid-flight.

    - stdoutLogEnabled="true" The .NET process logs its boot output to
                              .\logs\stdout_<pid>_<ts>.log. Serilog only starts
                              writing to logs\log-*.txt AFTER WebApplication
                              boots, so a crash during DI/seed/migration would
                              otherwise leave zero diagnostic trail.

    - WebDAV remove           IIS ships with the WebDAV module which silently
                              hijacks PUT/PATCH/DELETE verbs before they reach
                              the .NET handler, returning a 405 page that looks
                              like our API is broken. Removing the handler AND
                              the module is the established fix for ASP.NET
                              Core apps on IIS that expose REST endpoints with
                              those verbs (our profile-edit, vendor-update,
                              and user-management endpoints all do).
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <remove name="WebDAV" />
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <modules runAllManagedModulesForAllRequests="false">
        <remove name="WebDAVModule" />
      </modules>
      <aspNetCore processPath="dotnet"
                  arguments=".\AndritzVendorPortal.API.dll"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess"
                  startupTimeLimit="300"
                  requestTimeout="00:05:00" />
    </system.webServer>
  </location>
</configuration>
