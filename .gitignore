# --- Custom Andritz Portal Rules ---
# Ignore local SQLite databases (prevents overwriting live data)
*.db
*.db-shm
*.db-wal

# Ignore environment files with sensitive keys
.env
.env.local
.env.*.local

# Ignore build artifacts (anywhere in repo)
bin/
obj/
.vs/
*.user
*.lscache
node_modules/
dist/

# Recovery backup of corrupted .git metadata — kept locally for safety, never committed
.git.broken-backup/

# API runtime artifacts: SPA bundle is produced by the Dockerfile, Serilog writes logs/ at runtime
src/API/wwwroot/
src/API/logs/

# Claude Code per-project metadata (auto-memory, settings, etc.)
.claude/