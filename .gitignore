# --- Custom Andritz Portal Rules ---
# Ignore local SQLite databases (prevents overwriting live data)
*.db
*.db-shm
*.db-wal

# Ignore environment files with sensitive keys
.env
.env.local
.env.*.local

# Ignore build artifacts (anywhere in repo)
bin/
obj/
.vs/
*.user
*.lscache
node_modules/
dist/

# Recovery backup of corrupted .git metadata — kept locally for safety, never committed
.git.broken-backup/

# API runtime artifacts: SPA bundle is produced by the Dockerfile, Serilog writes logs/ at runtime
src/API/wwwroot/
src/API/logs/

# Claude Code per-project metadata (auto-memory, settings, etc.)
.claude/

# Publish bundles and any side-by-side variants (publish_out, publish_out v3, etc.) plus the zips
publish_out/
publish_out*/
publish_out*.zip

# Root-level runtime log directory (different from src/API/logs/)
/logs/

# Local SQL bootstrap scripts and SQL Server backup files — not part of the app
*.sql
*.bak

# Scratch projects (one-off tools that aren't part of the build)
_hashgen/